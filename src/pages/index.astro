---
import PortalLayout from '../layouts/PortalLayout.astro';
---

<PortalLayout title="Rock Roqué — Mind Portal">
  <div class="portal">
    <svg
      class="neural-glyph"
      viewBox="0 0 200 200"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
      width="160"
      height="160"
    >
      <!-- Concentric circles -->
      <circle cx="100" cy="100" r="80" fill="none" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.3" />
      <circle cx="100" cy="100" r="55" fill="none" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.5" />
      <circle cx="100" cy="100" r="30" fill="none" stroke="var(--color-accent)" stroke-width="1" opacity="0.8" />
      <!-- Center node -->
      <circle cx="100" cy="100" r="4" fill="var(--color-accent)" />
      <!-- Radiating node lines -->
      <line x1="100" y1="100" x2="100" y2="20" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <line x1="100" y1="100" x2="170" y2="55" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <line x1="100" y1="100" x2="170" y2="145" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <line x1="100" y1="100" x2="100" y2="180" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <line x1="100" y1="100" x2="30" y2="145" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <line x1="100" y1="100" x2="30" y2="55" stroke="var(--color-accent)" stroke-width="0.5" opacity="0.4" />
      <!-- Outer nodes -->
      <circle cx="100" cy="20" r="3" fill="var(--color-accent)" opacity="0.6" />
      <circle cx="170" cy="55" r="3" fill="var(--color-accent)" opacity="0.6" />
      <circle cx="170" cy="145" r="3" fill="var(--color-accent)" opacity="0.6" />
      <circle cx="100" cy="180" r="3" fill="var(--color-accent)" opacity="0.6" />
      <circle cx="30" cy="145" r="3" fill="var(--color-accent)" opacity="0.6" />
      <circle cx="30" cy="55" r="3" fill="var(--color-accent)" opacity="0.6" />
    </svg>

    <h1 class="portal__title">Rock Roqué</h1>
    <p class="portal__subtitle">Design Engineer · Civic Technologist</p>

    <div class="portal__status" aria-live="polite">
      <span class="portal__status-dot"></span>
      <span>Mind Portal initializing...</span>
    </div>
  </div>
</PortalLayout>

<style>
  .portal {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 100vh;
    text-align: center;
    padding: var(--space-lg);
  }

  .neural-glyph {
    margin-bottom: var(--space-xl);
    animation: glyph-pulse 4s var(--ease-in-out) infinite;
  }

  @keyframes glyph-pulse {
    0%, 100% { opacity: 0.8; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.03); }
  }

  .portal__title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-sm);
  }

  .portal__subtitle {
    font-size: var(--text-md);
    color: var(--color-text-muted);
    margin-bottom: var(--space-xl);
  }

  .portal__status {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .portal__status-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    animation: dot-pulse 2s var(--ease-in-out) infinite;
  }

  @keyframes dot-pulse {
    0%, 100% { opacity: 0.4; box-shadow: 0 0 0 0 var(--color-accent-glow); }
    50% { opacity: 1; box-shadow: 0 0 12px 4px var(--color-accent-glow); }
  }

  @media (prefers-reduced-motion: reduce) {
    .neural-glyph,
    .portal__status-dot {
      animation: none;
      opacity: 1;
    }
  }
</style>
