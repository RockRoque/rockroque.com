---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="portal">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Rock Roqué's Mind Portal — an explorable map of a mind" />
    <link rel="icon" type="image/svg+xml" href="/rockroque.com/favicon.svg" />
    <title>{title}</title>
    <style>
      @import '../styles/global.css';
      @import '../styles/themes/portal.css';
    </style>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <main id="main">
      <slot />
    </main>
  </body>
</html>
